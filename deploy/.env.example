# LandShark Production Environment Variables
# Copy to /opt/landshark/.env and fill in values

# Django
DJANGO_SECRET_KEY=change-me-to-a-random-50-char-string
DJANGO_DEBUG=false
DJANGO_SETTINGS_MODULE=config.settings
DJANGO_ALLOWED_HOSTS=45-55-48-26.nip.io

# Database (local PostgreSQL)
DATABASE_URL=postgresql://landshark:CHANGE_ME@localhost:5432/landshark

# CORS / CSRF
CORS_ALLOWED_ORIGINS=https://45-55-48-26.nip.io
CSRF_TRUSTED_ORIGINS=https://45-55-48-26.nip.io

# Field encryption (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
FIELD_ENCRYPTION_KEY=change-me-generate-a-fernet-key

# DO Spaces (S3-compatible storage) — optional, leave empty to use local media/
DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_BUCKET=landshark-staging
DO_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
DO_SPACES_REGION=nyc3

# Django-Q2 workers — split into two named pools.
#
# `Q_WORKERS_DEFAULT` sizes the standard-tier pool (landshark-worker.service).
# `Q_WORKERS_ENTERPRISE` sizes the isolated enterprise pool
# (landshark-worker-enterprise.service). Analyses are routed by
# `Organization.tier` (see backend/apps/analysis/views.py::_cluster_for_user).
#
# IMPORTANT: total concurrent analyses = Q_WORKERS_DEFAULT + Q_WORKERS_ENTERPRISE.
# Each worker renders up to 40 PDF pages into memory and calls an external AI
# API — they're memory-bound, not CPU-bound. Rough budget: 0.5–1GB peak per
# worker. Combined total should stay well under available RAM. The 2GB staging
# droplet can only fit 1 total worker; the deploy.sh adds a 4GB swap file as a
# safety net but is not a substitute for sizing this correctly.
#
# Suggested sizing:
#   2GB  RAM → Q_WORKERS_DEFAULT=1  Q_WORKERS_ENTERPRISE=0  (or skip enterprise pool)
#   4GB  RAM → Q_WORKERS_DEFAULT=2  Q_WORKERS_ENTERPRISE=1
#   8GB  RAM → Q_WORKERS_DEFAULT=4  Q_WORKERS_ENTERPRISE=2
#   16GB RAM → Q_WORKERS_DEFAULT=8  Q_WORKERS_ENTERPRISE=4
#
# Legacy `Q_WORKERS` is still read as a fallback for Q_WORKERS_DEFAULT until
# all hosts are migrated; remove it from your .env once both vars are set.
Q_WORKERS_DEFAULT=1
Q_WORKERS_ENTERPRISE=1

# Backup destination (separate bucket, separate region, separate credentials)
# Create a second DO Spaces bucket in a different region for disaster recovery.
# Generate a separate Spaces API key for isolation from the primary media key.
BACKUP_SPACES_KEY=
BACKUP_SPACES_SECRET=
BACKUP_SPACES_BUCKET=landshark-backups
BACKUP_SPACES_ENDPOINT=https://sfo3.digitaloceanspaces.com
BACKUP_SPACES_REGION=sfo3
